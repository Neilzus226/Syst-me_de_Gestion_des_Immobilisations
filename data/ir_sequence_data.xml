<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!-- Séquence pour le stock (IMO/2026/0001) -->
    <record id="seq_sigi_stock_matiere" model="ir.sequence">
        <field name="name">Séquence Inventaire Unités</field>
        <field name="code">sigi.stock.matiere.sequence</field>
        <field name="prefix">IMO/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>
    <!-- Séquence pour l'affectation (001) -->
    <record id="seq_sigi_affectation" model="ir.sequence">
        <field name="name">Séquence Affectation</field>
        <field name="code">sigi.affectation.code</field>
        <field name="prefix"></field>
        <field name="padding">3</field>
        <field name="company_id" eval="False"/>
    </record>

     <!-- Séquence pour l'affectation (001) -->
    <record id="seq_sigi_mutation" model="ir.sequence">
        <field name="name">Séquence Mutation SIGI</field>
        <field name="code">sigi.mutation</field>
        <field name="prefix">MUT/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

     <!-- Séquence pour les sorties -->
    <record id="seq_sigi_sortie" model="ir.sequence">
        <field name="name">Séquence Sortie SIGI</field>
        <field name="code">sigi.sortie</field>
        <field name="prefix">SRT/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

     <!-- Séquence pour entrée des matières -->
    <record id="seq_sigi_entrer_matiere" model="ir.sequence">
        <field name="name">Séquence Entrée Matière SIGI</field>
        <field name="code">sigi.entrer_matiere</field>
        <field name="prefix">ENT/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- Séquence pour inventaire -->
    <record id="seq_sigi_inventaire" model="ir.sequence">
            <field name="name">Séquence Inventaire SIGI</field>
            <field name="code">sigi.inventaire</field>
            <field name="prefix">INV/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
    </record>
</odoo>