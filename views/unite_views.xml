<?xml version="1.0" encoding="utf-8"?>
<odoo>

   # vue liste pour les marques
    <record id="view_sigi_unite_list" model="ir.ui.view">
        <field name="name">sigi.unite.list</field>
        <field name="model">sigi.unite</field>
        <field name="arch" type="xml">
            <list string="Liste des unite">
                <field name="name"/> 
            </list>
        </field>
    </record> 


    #vue formulaire pour les marques
    <record id="view_sigi_marque_form" model="ir.ui.view">
        <field name="name">sigi.unite.form</field>
        <field name="model">sigi.unite</field>
        <field name="arch" type="xml">
            <form string=" unite">
                <header>
                    <button name="action_valider"  string="Enregistrer" type="object" class="btn btn-success"/>
                </header>
                <sheet>
                    <group>
                            <field name="name" />
                            <field name="symbole" />
                    </group>
                </sheet>
                 <chatter/>
            </form>
        </field>
    </record>


    #action pour les marques
    <record id="action_sigi_unite" model="ir.actions.act_window">
        <field name="name">unite</field>
        <field name="res_model">sigi.unite</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>