<?xml version="1.0" encoding="utf-8"?>
<odoo>

   # vue liste pour les Natures
    <record id="view_sigi_nature_list" model="ir.ui.view">
        <field name="name">sigi.nature.list</field>
        <field name="model">sigi.nature</field>
        <field name="arch" type="xml">
            <list string="Liste des Unités disponibles">
                <field name="code" />
                <field name="name"/>
            </list>
        </field>
    </record> 


    #vue formulaire pour les Natures
    <record id="view_sigi_nature_form" model="ir.ui.view">
        <field name="name">sigi.nature.form</field>
        <field name="model">sigi.nature</field>
        <field name="arch" type="xml">
            <form string="Nature des aquisitions">
                <header>
                    <button name="action_valider"  string="Enregistrer" type="object" class="btn btn-success"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="code" />
                        </group>
                    
                        <group>
                            <field name="name"/>
                        </group> 
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>


    #action pour les Natures
    <record id="action_sigi_nature" model="ir.actions.act_window">
        <field name="name">nature</field>
        <field name="res_model">sigi.nature</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>