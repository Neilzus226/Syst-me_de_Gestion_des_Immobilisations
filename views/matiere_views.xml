<?xml version="1.0" encoding="utf-8"?>
<odoo>

   # vue liste pour les matières
    <record id="view_sigi_matiere_list" model="ir.ui.view">
        <field name="name">sigi.matiere.list</field>
        <field name="model">sigi.matiere</field>
        <field name="arch" type="xml">
            <list string="Liste des matières">
                <field name="code" />
                <field name="name"/> 
                <field name="duree" />
            </list>
        </field>
    </record> 


    #vue formulaire pour les matieres
    <record id="view_sigi_matiere_form" model="ir.ui.view">
        <field name="name">sigi.matiere.form</field>
        <field name="model">sigi.matiere</field>
        <field name="arch" type="xml">
            <form string="Les matières">
                <header>
                    <button name="action_valider"  string="Enregistrer" type="object" class="btn btn-success"/>
                </header>
                <sheet>
                    <group>
                        
                        <group>
                            <field name="code" />
                        </group>

                        <group>
                            <field name="name" />
                        </group>

                        <group>
                            <field name="duree" />
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    #action pour les matières
    <record id="action_sigi_matiere" model="ir.actions.act_window">
        <field name="name">matiere</field>
        <field name="res_model">sigi.matiere</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>