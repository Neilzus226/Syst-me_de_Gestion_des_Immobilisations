<?xml version="1.0" encoding="utf-8"?>
<odoo>

   # vue liste pour les modèles
    <record id="view_sigi_modele_list" model="ir.ui.view">
        <field name="name">sigi.modele.list</field>
        <field name="model">sigi.modele</field>
        <field name="arch" type="xml">
            <list string="Liste des marque">
                <field name="code" />
                <field name="name"/> 
            </list>
        </field>
    </record> 


    #vue formulaire pour les modele
    <record id="view_sigi_modele_form" model="ir.ui.view">
        <field name="name">sigi.modele.form</field>
        <field name="model">sigi.modele</field>
        <field name="arch" type="xml">
            <form string=" modele">
                <header>
                    <button name="action_valider"  string="Enregistrer" type="object" class="btn btn-success"/>
                </header>
                <sheet>
                    <group> 
                            <field name="code" />
                            <field name="name" />
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>


    #action pour les modele
    <record id="action_sigi_modele" model="ir.actions.act_window">
        <field name="name">modele</field>
        <field name="res_model">sigi.modele</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>