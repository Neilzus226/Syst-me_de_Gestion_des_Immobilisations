<?xml version="1.0" encoding="utf-8"?>
<odoo>

   # vue liste pour les Directions
    <record id="view_sigi_direction_list" model="ir.ui.view">
        <field name="name">sigi.direction.list</field>
        <field name="model">sigi.direction</field>
        <field name="arch" type="xml">
            <list string="Liste des Direction">
                <field name="code"/>
                <field name="name"/> 
            </list>
        </field>
    </record> 


    #vue formulaire pour les Direction
    <record id="view_sigi_direction_form" model="ir.ui.view">
        <field name="name">sigi.direction.form</field>
        <field name="model">sigi.direction</field>
        <field name="arch" type="xml">
            <form string="direction de affactations">
                <header>
                    <button name="action_valider"  string="Enregistrer" type="object" class="btn btn-success"/>
                </header>
                <sheet>
                    <group>
                        
                        <group>
                            <field name="code"/>
                        </group>

                        <group>
                            <field name="name"/>
                        </group>
                        
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>


    #action pour les direction
    <record id="action_sigi_direction" model="ir.actions.act_window">
        <field name="name">direction</field>
        <field name="res_model">sigi.direction</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>