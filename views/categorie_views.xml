<?xml version="1.0" encoding="utf-8"?>
<odoo>

   # vue liste pour les categories
    <record id="view_sigi_categorie_list" model="ir.ui.view">
        <field name="name">sigi.categorie.list</field>
        <field name="model">sigi.categorie</field>
        <field name="arch" type="xml">
            <list string="Liste des categorie">
                <field name="code"/> 
                <field name="name"/> 
                <field name="methode"/> 
            </list>
        </field>
    </record> 


    #vue formulaire pour les categorie
    <record id="view_sigi_categorie_form" model="ir.ui.view">
        <field name="name">sigi.categorie.form</field>
        <field name="model">sigi.categorie</field>
        <field name="arch" type="xml">
            
            <form string=" categorie">
                <header>
                    <button name="action_valider"  string="Enregistrer" type="object" class="btn btn-success"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="code"/> 
                            <field name="name" />
                        </group>

                        <group>
                            <field name="methode"/> 
                        </group>
                        
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    #action pour les categorie
    <record id="action_sigi_categorie" model="ir.actions.act_window">
        <field name="name">categorie</field>
        <field name="res_model">sigi.categorie</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>