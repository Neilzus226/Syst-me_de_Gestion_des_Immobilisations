<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_sigi_inventaire_list" model="ir.ui.view">
        <field name="name">sigi.inventaire.list</field>
        <field name="model">sigi.inventaire</field>
        <field name="arch" type="xml">
            <list string="Sessions d'Inventaire" decoration-info="state == 'draft'" decoration-success="state == 'done'">
                <field name="name"/>
                <field name="date_inventaire"/>
                <field name="responsable_id"/>
                <field name="total_en_service" sum="Total Service"/>
                <field name="total_amortis" sum="Total Amortis"/>
                <field name="total_sortis" sum="Total Sortis"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'done'"/>
            </list>
        </field>
    </record>

    <record id="view_sigi_inventaire_form" model="ir.ui.view">
        <field name="name">sigi.inventaire.form</field>
        <field name="model">sigi.inventaire</field>
        <field name="arch" type="xml">
            <form string="Session d'Inventaire">
                <header>
                    <button name="action_cloturer" string="Clôturer l'Inventaire" 
                            type="object" class="oe_highlight" invisible="state == 'done'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Référence Session"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Informations">
                            <field name="date_inventaire" readonly="state == 'done'"/>
                            <field name="responsable_id" readonly="state == 'done'"/>
                        </group>
                        <group string="Résumé du Patrimoine">
                            <field name="total_biens" style="font-weight: bold;"/>
                            <field name="total_en_service" style="color: green;"/>
                            <field name="total_amortis" style="color: blue;"/>
                            <field name="total_sortis" style="color: red;"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_sigi_affectation_ligne_search_inventaire" model="ir.ui.view">
        <field name="name">sigi.affectation_ligne.search.inventaire</field>
        <field name="model">sigi.affectation_ligne</field>
        <field name="arch" type="xml">
            <search string="Recherche Inventaire">
                <field name="name"/>
                <field name="matiere_id"/>
                <group expand="1" string="Regrouper par">
                    <filter string="État (Service/Amorti/Sorti)" name="group_etat" 
                            context="{'group_by': 'etat_amortissement'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_sigi_inventaire" model="ir.actions.act_window">
        <field name="name">Sessions d'Inventaire</field>
        <field name="res_model">sigi.inventaire</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_rapport_patrimoine_groupe" model="ir.actions.act_window">
        <field name="name">État Global du Patrimoine</field>
        <field name="res_model">sigi.affectation_ligne</field>
        <field name="view_mode">list,pivot,graph</field>
        <field name="search_view_id" ref="view_sigi_affectation_ligne_search_inventaire"/>
        <field name="context">{'search_default_group_etat': 1}</field>
    </record>

    
</odoo>